# App
APP_NAME=Avana V2 - Karnataka Safety Intelligence Platform
VERSION=2.0.0
DEBUG=false

# Database (Supabase or any PostgreSQL 16+ with PostGIS)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=

# Connection pooling (Supabase free tier: 15 connections max)
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_SSL_MODE=require

# JWT (generate a 64+ char secret key)
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Provider (OpenRouter recommended — free tier available)
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Karnataka Geo Bounds (lat_min,lat_max,lng_min,lng_max)
KARNATAKA_BOUNDS=11.5,18.0,74.0,78.5

# SendGrid Email (Free Tier)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=sos@avana-safety.app
SOS_NOTIFICATION_EMAIL_ENABLED=false

# Intelligence Pipeline
ENABLE_INTELLIGENCE_PIPELINE=true
