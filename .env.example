# App
APP_NAME=Avana V2 - Karnataka Safety Intelligence Platform
VERSION=2.0.0
DEBUG=false

# Database (Supabase Free Tier PostgreSQL)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=

# JWT (generate a 64+ char secret key)
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini AI (Free Tier - key must start with "AIza")
GEMINI_API_KEY=

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Karnataka Geo Bounds (lat_min,lat_max,lng_min,lng_max)
KARNATAKA_BOUNDS=11.5,18.0,74.0,78.5

# SendGrid Email (Free Tier)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=sos@avana-safety.app
SOS_NOTIFICATION_EMAIL_ENABLED=false

# Intelligence Pipeline
ENABLE_INTELLIGENCE_PIPELINE=true
