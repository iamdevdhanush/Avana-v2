# App
APP_NAME=Avana V2 - Karnataka Safety Intelligence
VERSION=2.0.0
DEBUG=false

# PostgreSQL / PostGIS
POSTGRES_USER=avana
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=avana_v2

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
SECRET_KEY=your_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Supabase (optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# AI Services
GEMINI_API_KEY=
OPENAI_API_KEY=

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Agent Intervals (minutes)
NEWS_SCRAPE_INTERVAL_MINUTES=360
AGENT_RUN_INTERVAL_MINUTES=60

# Karnataka Bounds (min_lat, max_lat, min_lng, max_lng)
KARNATAKA_BOUNDS=11.5,13.5,74.0,78.5
