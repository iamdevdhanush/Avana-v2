# Avana V2 — Environment Configuration
# Copy to .env and fill in values.
# No service here requires a paid plan.

# Application
APP_NAME=Avana V2 - Karnataka Safety Intelligence Platform
VERSION=2.0.0
DEBUG=false
API_PREFIX=/api/v1

# Supabase PostgreSQL + PostGIS (Free Tier)
# Get these from: Project Settings → Database → Connection string
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
# The async connection string:
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# JWT
SECRET_KEY=generate-a-random-64-char-string-here-minimum-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini AI (Free Tier: 60 req/min, 1500 req/day)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://avana-v2.vercel.app

# Rate Limiting (in-process, no Redis needed)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# Emailing (SOS notifications) — SendGrid Free: 100 emails/day
# Get from: https://sendgrid.com (Free Account)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=sos@avana-safety.app
SOS_NOTIFICATION_EMAIL_ENABLED=false

# Karnataka bounds
KARNATAKA_BOUNDS=11.5,18.0,74.0,78.5

# Feature flags
ENABLE_INTELLIGENCE_PIPELINE=true
